<section class="about-i">
  <div class="in-about container-i">
    <div class="head-about">
      {% if section.settings.heading != blank %}
        <div class="he-l uppercase">
          <div>{{ section.settings.heading }}</div>
        </div>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="bo-m">
          <p>{{ section.settings.text }}</p>
        </div>
      {% endif %}
    </div>
  </div>

  {% if section.blocks.size > 0 %}
    <div class="body-about">
      <div class="decor-about">
        {% for block in section.blocks %}
          <figure
            class="item-about item-about-{{ forloop.index }}"
            {% if block.settings.parallax_speed > 0 %}
              data-parallax="{{ block.settings.parallax_speed }}"
            {% endif %}
            {{ block.shopify_attributes }}
          >
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 420
                | image_tag:
                  loading: 'lazy',
                  widths: '120, 180, 240, 320, 420',
                  alt: block.settings.alt | default: section.settings.heading
              }}
            {% endif %}
          </figure>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "About I",
  "tag": "section",
  "class": "section-about-i",
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<h1>PROTEIN BARS MADE FOR <strong>INGREDIENT-OBSESSED PEOPLE</strong></h1>"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "We believe in fueling you with clean ingredients and high protein in every bite because what you put in your body should make sense"
    }
  ],
  "blocks": [
    {
      "type": "decor",
      "name": "Decor image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        },
        {
          "type": "range",
          "id": "parallax_speed",
          "label": "Parallax intensity",
          "info": "0 = sin parallax. Valores bajos (0.1) se sienten más anclados; altos (0.4) se mueven mucho con el scroll.",
          "min": 0,
          "max": 0.5,
          "step": 0.1,
          "default": 0.2
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "About I"
    }
  ]
}
{% endschema %}