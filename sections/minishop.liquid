{% liquid
  assign featured_collection = section.settings.collection
  if featured_collection == blank
    assign featured_collection = collections['frontpage']
  endif

  assign products_limit = 20
%}

<section class="shopping-i" id="minishop-{{ section.id }}">
  <div class="in-shopping container-i">
    <div class="head-shopping">
      {% if section.settings.heading != blank %}
        <div class="he-m fw-extrablack">
          <h2>{{ section.settings.heading }}</h2>
        </div>
      {% endif %}
    </div>

    {% if featured_collection != blank and featured_collection.products_count > 0 %}
      <div class="body-shopping">
        <div class="flex-i">
          {% for product in featured_collection.products limit: products_limit %}
            <div class="item-shopping" {{ product.shopify_attributes }} hidden>
              <div class="in-item-shopping">
                {% if section.settings.badge_text != blank %}
                  <div class="tag-shopping">
                    <div class="tag-i sp-s uppercase fw-semibold">
                      <span>{{ section.settings.badge_text }}</span>
                    </div>
                  </div>
                {% endif %}

                <div class="media-shopping">
                  <a href="{{ product.url }}">
                    {% if product.featured_image != blank %}
                      {{
                        product.featured_image
                        | image_url: width: 900
                        | image_tag:
                          loading: 'lazy',
                          widths: '640, 900',
                          alt: product.featured_image.alt | default: product.title
                      }}
                    {% endif %}

                    {% assign shopping_media = product.metafields.custom.shopping_media.value %}

                    {% if shopping_media != blank %}
                      <div class="media-metafield media-count-{{ shopping_media.size }}">
                        {% for media in shopping_media limit: 4 %}
                          <figure class="media-{{ forloop.index }}">
                            {{
                              media
                              | image_url: width: 500
                              | image_tag:
                                loading: 'lazy',
                                widths: '120, 180, 240, 320, 500',
                                alt: media.alt | default: product.title
                            }}
                          </figure>
                        {% endfor %}
                      </div>
                    {% endif %}
                  </a>
                </div>

                <div class="data-shopping">
                  <div class="title-shopping">
                    <a href="{{ product.url }}" class="he-s fw-extrablack uppercase">
                      {{ product.title }}
                    </a>
                  </div>

                  <div class="price-shopping">
                    <div class="sp-s fw-semibold uppercase">
                      <p>{{ product.price | money }}</p>
                    </div>
                  </div>

                  <div class="action-shopping">
                    <a href="{{ product.url }}" class="btn-i btn-pink-ii">
                      <span>{{ section.settings.button_label }}</span>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="body-shopping">
        <div class="bo-m">
          <p>No products found in this collection.</p>
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
  (() => {
    const root = document.getElementById('minishop-{{ section.id }}');
    if (!root) return;

    const wrapper = root.querySelector('.body-shopping .flex-i');
    if (!wrapper) return;

    const items = Array.from(wrapper.querySelectorAll('.item-shopping'));

    for (let i = items.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [items[i], items[j]] = [items[j], items[i]];
    }

    items.forEach((item, index) => {
      if (index < 3) {
        item.hidden = false;
        wrapper.appendChild(item);
      } else {
        item.remove();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Minishop",
  "tag": "section",
  "class": "section-minishop-i",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP JUSTNOSH"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "12 BARS"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP FLAVOR"
    }
  ],
  "presets": [
    {
      "name": "Minishop"
    }
  ]
}
{% endschema %}