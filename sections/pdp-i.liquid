      }
      */


    }


    function mountQuantityInsideSubscriptionWidget() {
      const root = document.getElementById(`pdp-i-${sectionId}`);
      if (!root) return;

      const productForm = root.querySelector('product-form-component form');
      if (!productForm) return;

      let observer = null;
      let rafScheduled = false;

      const moveQuantity = () => {
        const quantityWrapper = productForm.querySelector('.quantity-selector-wrapper');
        if (!quantityWrapper) return;

        const addToCartComponent = productForm.querySelector('add-to-cart-component');
        if (!addToCartComponent) return;

        const subscriptionWidget =
          addToCartComponent.querySelector('.sealsubs-target-element.sls-homepage-automatic') ||
          addToCartComponent.querySelector('.sealsubs-container');

        const addToCartButton = addToCartComponent.querySelector('button[type="submit"]');

        if (!subscriptionWidget || !addToCartButton) return;

        // 🔥 CLAVE: verificar si ya está en el lugar correcto
        const isCorrect =
          quantityWrapper.parentElement === addToCartComponent &&
          subscriptionWidget.nextElementSibling === quantityWrapper;

        if (isCorrect) return;

        // 🔥 mover dentro del add-to-cart-component
        addToCartComponent.insertBefore(quantityWrapper, addToCartButton);
      };

      const scheduleMove = () => {
        if (rafScheduled) return;
        rafScheduled = true;

        requestAnimationFrame(() => {
          rafScheduled = false;
          moveQuantity();
        });
      };

      moveQuantity();

      observer = new MutationObserver(() => {
        scheduleMove();
      });

      observer.observe(productForm, {
        childList: true,
        subtree: true
      });

      root._subscriptionQuantityObserver = observer;
    }




    function boot() {
      initRestOfSection();
      waitForSplide();
      mountQuantityInsideSubscriptionWidget();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot, { once: true });
    } else {
      boot();
    }

    document.addEventListener('shopify:section:load', (event) => {
      if (event.detail && event.detail.sectionId === sectionId) {
        const root = document.getElementById(`pdp-i-${sectionId}`);
        if (!root) return;

        if (root._subscriptionQuantityObserver) {
          root._subscriptionQuantityObserver.disconnect();
          root._subscriptionQuantityObserver = null;
        }

        root.dataset.pdpReady = '';
        root.dataset.pdpSplideMounted = '';
        boot();
      }
    });
  })();
</script>

{% schema %}
  {
    "name": "PDP I",
    "tag": "section",
    "class": "section-pdp-i",
    "settings": [
    ],
    "presets": [
      {
        "name": "PDP I"
      }
    ]
  }
{% endschema %}