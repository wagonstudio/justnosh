<section class="why-i">
  <div class="in-why container-i">
    <div class="head-why">
      {% if section.settings.heading != blank %}
        <div class="he-m fw-extrablack">
          <h2>{{ section.settings.heading }}</h2>
        </div>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="bo-m">
          <p>{{ section.settings.text }}</p>
        </div>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="body-why">
        <div class="flex-i ">
          {% for block in section.blocks %}
            <div class="item-why" {{ block.shopify_attributes }}>
              <div class="in-item-why">
                {% if block.settings.icon != blank %}
                  <div class="media-why">
                    {{ block.settings.icon | image_url: width: 180 | image_tag: loading: 'lazy', alt: block.settings.title | escape }}
                  </div>
                {% endif %}

                <div class="data-why">
                  {% if block.settings.title != blank %}
                    <div class="he-xs fw-semibold">
                      <h3>{{ block.settings.title }}</h3>
                    </div>
                  {% endif %}

                  {% if block.settings.text != blank %}
                    <div class="bo-m">
                      <p>{{ block.settings.text }}</p>
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Why",
  "tag": "section",
  "class": "section-why-i",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHY JUSTNOSH"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "We choose organically sourced ingredients wherever possible. Not as a trend, but because quality and transparency matter to us."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Why item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "14-16g protein"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Including 10g Grass-Fed Collagen"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Why",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "title": "14-16g protein",
            "text": "Including 10g Grass-Fed Collagen"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Easy to digest",
            "text": "Gluten-Free, Dairy-Free, FODMAP Friendly"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "No fillers",
            "text": "No Artificial Flavors"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Certified seed oil free",
            "text": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}